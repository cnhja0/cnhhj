      "versionNonce": 1149760577,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771979507781,
      "link": null,
      "locked": false,
      "text": "100%\n\nFundador Majoritário -  50% - CEO\n\nMarketing - 20%\n\nDev  Bruno 1 -  15%\n \nDev Cebolinha 2 - 15%\n\n\n\n\nShinji\n\nFundador - 35%\n\nCo-founder - 30%\n\nDev buiu - 17,5%\n\nDev ivan - 17,5%\n\n\n\n\nBruno\n\nFundador - 35%\n\nMkt - 30%\n\ndev buiu - 20%\n\nDev ivan - 15%",
      "fontSize": 8.355555555555563,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "100%\n\nFundador Majoritário -  50% - CEO\n\nMarketing - 20%\n\nDev  Bruno 1 -  15%\n \nDev Cebolinha 2 - 15%\n\n\n\n\nShinji\n\nFundador - 35%\n\nCo-founder - 30%\n\nDev buiu - 17,5%\n\nDev ivan - 17,5%\n\n\n\n\nBruno\n\nFundador - 35%\n\nMkt - 30%\n\ndev buiu - 20%\n\nDev ivan - 15%",
      "autoResize": false,
      "lineHeight": 1.25
    },
